NODE_ENV=development
PORT=3002

MONGODB_URI=mongodb://localhost:27017/itsm-agent
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=itsm-ai-service
KAFKA_GROUP_ID=itsm-ai-group

# AI Detection thresholds
CPU_THRESHOLD=85
MEMORY_THRESHOLD=90
DISK_THRESHOLD=80
ERROR_RATE_THRESHOLD=5
RESPONSE_TIME_THRESHOLD=2000

# Scan interval (milliseconds)
HARDWARE_SCAN_INTERVAL=30000
SOFTWARE_SCAN_INTERVAL=60000

# Backend API (for ticket creation fallback)
BACKEND_API_URL=http://localhost:3001/api
BACKEND_API_KEY=internal-service-key
