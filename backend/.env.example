# App
NODE_ENV=development
PORT=3001
API_PREFIX=api

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/itsm-agent

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=itsm-backend
KAFKA_GROUP_ID=itsm-backend-group

# Company Email Domain
COMPANY_EMAIL_DOMAIN=company.com

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WORKSPACE_ID=your-workspace-id

# GitHub
GITHUB_TOKEN=ghp_your-github-token
GITHUB_ORG=your-github-org

# Google Workspace
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADMIN_EMAIL=admin@company.com
GOOGLE_DOMAIN=company.com

# Microsoft 365
MS365_TENANT_ID=your-tenant-id
MS365_CLIENT_ID=your-client-id
MS365_CLIENT_SECRET=your-client-secret

# Jira
JIRA_HOST=https://yourcompany.atlassian.net
JIRA_EMAIL=admin@company.com
JIRA_API_TOKEN=your-jira-api-token

# Zoom
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Zoho
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# ServiceNow
SERVICENOW_INSTANCE=https://yourinstance.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password

# SAP
SAP_HOST=https://your-sap-host
SAP_CLIENT=100
SAP_USERNAME=your-sap-user
SAP_PASSWORD=your-sap-password

# Salesforce
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_USERNAME=admin@company.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_SECURITY_TOKEN=your-security-token

# Blazey Integration
BLAZEY_WEBHOOK_SECRET=your-blazey-webhook-secret
BLAZEY_API_URL=https://api.blazey.io
